 <!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Investing Copilot | Portfolio & Asset Analytics</title>
    <style>
        :root {
            --bg-color: #0f1115;
            --panel-bg: #161920;
            --accent-color: #6366f1;
            --text-main: #f3f4f6;
            --text-muted: #9ca3af;
            --border-color: #1f2937;
        }

        body {
            margin: 0;
            padding: 0;
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        header {
            padding: 1rem 2rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background-color: var(--panel-bg);
        }

        .brand-logo-container {
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }

        .app-logo {
            height: 32px; /* You can adjust this height to match your logo asset's proportions */
            width: auto;
            display: block;
        }

        .brand {
            font-weight: 700;
            font-size: 1.25rem;
            letter-spacing: -0.025em;
        }

        .brand span {
            color: var(--accent-color);
        }

        main {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 3rem 2rem;
            text-align: center;
            max-width: 800px;
            margin: 0 auto;
        }

        .tagline {
            color: var(--accent-color);
            text-transform: uppercase;
            font-size: 0.85rem;
            font-weight: 600;
            letter-spacing: 0.1em;
            margin-bottom: 1rem;
        }

        h1 {
            font-size: 3rem;
            font-weight: 800;
            letter-spacing: -0.03em;
            margin: 0 0 1.5rem 0;
            line-height: 1.15;
        }

        p {
            color: var(--text-muted);
            font-size: 1.15rem;
            line-height: 1.6;
            margin: 0 0 2.5rem 0;
            max-width: 600px;
        }

        .cta-button {
            display: inline-block;
            background-color: var(--accent-color);
            color: #ffffff;
            text-decoration: none;
            padding: 0.85rem 2rem;
            border-radius: 6px;
            font-weight: 600;
            font-size: 1rem;
            transition: background 0.2s ease;
            box-shadow: 0 4px 12px rgba(99, 102, 241, 0.2);
        }

        .cta-button:hover {
            background-color: #4f46e5;
        }

        footer {
            padding: 1.5rem;
            text-align: center;
            font-size: 0.85rem;
            color: var(--text-muted);
            border-top: 1px solid var(--border-color);
            background-color: var(--panel-bg);
        }
    </style>
</head>
<body>

    <header>
        <div class="brand-logo-container">
            <img src="logo.png" alt="Investing Copilot Logo" class="app-logo">
            <div class="brand">Investing<span>Copilot</span></div>
        </div>
    </header>

    <main>
        <div class="tagline">Workstation-Oriented Data Visualization</div>
        <h1>High-Density Analytics for Hard Assets & Equities</h1>
        <p>
            Track your holdings, map your long-term position metrics, and gain complete portfolio clarity without navigational noise or retail bubble hype.
        </p>
        
        <a href="https://investingcopilot.gardenshedclay.com/login" class="cta-button">
            Launch Terminal
        </a>
    </main>

    <footer>
        &copy; 2026 Garden Shed Clay LLC. All rights reserved.
    </footer>

</body>
</html>
